---
import { withBase } from '../lib/url';

const currentYear = new Date().getFullYear();

const footerLinks = {
  services: [
    { href: '/course', label: 'קורס קריפטו מאפס למאה' },
    { href: '/course/live', label: 'מחזור לייב' },
    { href: '/services/personal-escort', label: 'ליווי פרטני' },
    { href: '/services/strategic-meeting', label: 'פגישת אסטרטגיה' },
    { href: '/services/lectures', label: 'הרצאות' },
    { href: '/books', label: 'ספרונים קצרים' },
  ],
  guides: [
    { href: '/guides/how-to-buy-and-sell', label: 'איך קונים ומוכרים' },
    { href: '/guides/evreything-about-digital-wallet', label: 'ארנק דיגיטלי' },
    { href: '/guides/digital-wallet-practical', label: 'הדגמת ארנק חם' },
    { href: '/guides/tax', label: 'מיסוי קריפטו' },
    { href: '/guides/cold-wallet-guide', label: 'ארנק קר' },
    { href: '/guides/how-and-risks', label: 'ניהול סיכונים' },
  ],
  blog: [
    { href: '/blog', label: 'כל המאמרים' },
    { href: '/blog/category/מיינדסט', label: 'מיינדסט' },
    { href: '/blog/category/השקעות', label: 'השקעות' },
    { href: '/blog/category/ביטקוין', label: 'ביטקוין' },
    { href: '/blog/category/בלוקצ\'יין', label: 'בלוקצ\'יין' },
  ],
  social: [
    {
      href: 'https://www.instagram.com/cryptowomen_il/',
      label: 'אינסטגרם',
      icon: 'instagram',
    },
    {
      href: 'https://www.facebook.com/cryptowomenil/',
      label: 'פייסבוק',
      icon: 'facebook',
    },
    {
      href: 'https://www.youtube.com/@cryptowomen_il',
      label: 'יוטיוב',
      icon: 'youtube',
    },
    {
      href: 'https://wa.me/972546227530',
      label: 'וואטסאפ',
      icon: 'whatsapp',
    },
    {
      href: 'https://www.linkedin.com/in/keren-valdman/',
      label: 'לינקדאין',
      icon: 'linkedin',
    },
  ],
};
---

<footer class="site-footer" aria-labelledby="footer-heading">
  <h2 class="sr-only" id="footer-heading">Crypto Women — פוטר</h2>

  <!-- Main Footer Content -->
  <div class="footer-main">
    <div class="container footer-grid">
      <!-- Brand Column -->
      <div class="footer-brand">
        <a href={withBase('/')} class="footer-logo" aria-label="Crypto Women — חזרה לדף הבית">
          <span class="footer-logo-text">Crypto Women</span>
        </a>
        <p class="footer-tagline">
          ביטקוין, בלוקצ'יין וקריפטו — ידע ומדריכים לנשים (וגברים) שרוצים להשקיע בצורה בטוחה ונכונה
        </p>
        <!-- Social Links -->
        <div class="social-links" aria-label="רשתות חברתיות">
          {footerLinks.social.map((s) => (
            <a
              href={s.href}
              class="social-link"
              aria-label={s.label}
              rel="noopener noreferrer"
              target="_blank"
            >
              {s.icon === 'instagram' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                </svg>
              )}
              {s.icon === 'facebook' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
              )}
              {s.icon === 'youtube' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                </svg>
              )}
              {s.icon === 'whatsapp' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
                </svg>
              )}
              {s.icon === 'linkedin' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              )}
            </a>
          ))}
        </div>
        <!-- WhatsApp CTA -->
        <a href="https://wa.me/972546227530" class="btn btn--ghost footer-wa" rel="noopener noreferrer" target="_blank">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
          </svg>
          דברי איתי בוואטסאפ
        </a>
      </div>

      <!-- Services Column -->
      <div class="footer-col">
        <h3 class="footer-col-title">שירותים</h3>
        <ul class="footer-link-list" role="list">
          {footerLinks.services.map((l) => (
            <li><a href={withBase(l.href)} class="footer-link">{l.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Guides Column -->
      <div class="footer-col">
        <h3 class="footer-col-title">מדריכים</h3>
        <ul class="footer-link-list" role="list">
          {footerLinks.guides.map((l) => (
            <li><a href={withBase(l.href)} class="footer-link">{l.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Blog Column -->
      <div class="footer-col">
        <h3 class="footer-col-title">בלוג</h3>
        <ul class="footer-link-list" role="list">
          {footerLinks.blog.map((l) => (
            <li><a href={withBase(l.href)} class="footer-link">{l.label}</a></li>
          ))}
        </ul>
        <div style="margin-block-start: var(--space-4);">
          <a href={withBase('/contact')} class="footer-link font-bold">צור קשר</a>
        </div>
        <div style="margin-block-start: var(--space-2);">
          <a href={withBase('/about')} class="footer-link font-bold">עליי</a>
        </div>
        <div style="margin-block-start: var(--space-2);">
          <a href={withBase('/media')} class="footer-link font-bold">מדיה</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p class="footer-copy">
        &copy; {currentYear} Crypto Women — קרן ולדמן חנן. כל הזכויות שמורות.
      </p>
      <p class="footer-disclaimer">
        האמור באתר אינו מהווה ייעוץ פיננסי ואינו תחליף לייעוץ מקצועי.
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--gradient-hero);
    color: rgba(255,255,255,0.85);
    margin-block-start: var(--space-24);
  }

  .footer-main {
    padding-block: var(--space-16);
    border-block-end: 1px solid rgba(255,255,255,0.1);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: var(--space-12);
    align-items: start;
  }

  .footer-brand {}

  .footer-logo {
    display: inline-block;
    margin-block-end: var(--space-4);
    transition: opacity var(--transition-fast);
  }

  .footer-logo:hover { opacity: 0.85; }

  .footer-logo-text {
    font-size: 1.6rem;
    font-weight: 900;
    color: white;
    letter-spacing: 0;
    background: linear-gradient(90deg, #fff 0%, var(--color-accent-light, #f0d080) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .footer-tagline {
    font-size: var(--text-sm);
    line-height: 1.7;
    opacity: 0.8;
    margin-block-end: var(--space-6);
    max-width: 28ch;
  }

  .social-links {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-block-end: var(--space-6);
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-full);
    background: rgba(255,255,255,0.1);
    color: white;
    transition: all var(--transition-base);
    border: 1px solid rgba(255,255,255,0.15);
  }

  .social-link:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
    transform: translateY(-2px);
    color: white;
  }

  .footer-wa {
    font-size: 0.875rem;
    padding: var(--space-2) var(--space-5);
  }

  .footer-col-title {
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent-light);
    margin-block-end: var(--space-4);
    padding-block-end: var(--space-2);
    border-block-end: 1px solid rgba(255,255,255,0.1);
  }

  .footer-link-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer-link {
    font-size: var(--text-sm);
    color: rgba(255,255,255,0.75);
    transition: all var(--transition-fast);
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
  }

  .footer-link:hover {
    color: var(--color-accent-light);
    padding-inline-end: var(--space-2);
  }

  .footer-bottom {
    padding-block: var(--space-4);
  }

  .footer-bottom-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .footer-copy {
    font-size: var(--text-xs);
    opacity: 0.65;
    margin: 0;
    max-width: unset;
  }

  .footer-disclaimer {
    font-size: var(--text-xs);
    opacity: 0.5;
    margin: 0;
    max-width: unset;
  }

  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }

    .footer-bottom-inner {
      flex-direction: column;
      text-align: center;
    }

    .footer-tagline {
      max-width: 100%;
    }
  }
</style>
