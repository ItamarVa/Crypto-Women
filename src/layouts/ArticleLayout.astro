---
import BaseLayout from './BaseLayout.astro';
import Cta from '../components/Cta.astro';

export interface Props {
  title: string;
  description?: string;
  pubDate?: Date;
  heroImage?: string;
  category?: string;
  tags?: string[];
}

const { title, description, pubDate, heroImage, category, tags = [] } = Astro.props;

const formattedDate = pubDate
  ? new Intl.DateTimeFormat('he-IL', { year: 'numeric', month: 'long', day: 'numeric' }).format(new Date(pubDate))
  : null;

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  datePublished: pubDate?.toISOString(),
  publisher: {
    '@type': 'Organization',
    name: 'Crypto Women',
    logo: { '@type': 'ImageObject', url: 'https://cryptowomen-il.com/images/logo.jpg' },
  },
  author: {
    '@type': 'Person',
    name: 'קרן ולדמן חנן',
    url: 'https://cryptowomen-il.com/about',
  },
};
---

<BaseLayout
  title={title}
  description={description}
  image={heroImage}
  ogType="article"
  {structuredData}
>
  <article class="article-page">
    <!-- Hero Image -->
    {heroImage && (
      <div class="article-hero">
        <img
          src={heroImage}
          alt={title}
          width="1200"
          height="630"
          loading="eager"
          decoding="async"
          class="article-hero-img"
        />
      </div>
    )}

    <div class="container--content">
      <!-- Article Header -->
      <header class="article-header">
        {category && (
          <a href={`/blog/category/${encodeURIComponent(category)}`} class="badge badge--accent">
            {category}
          </a>
        )}
        <h1 class="article-title">{title}</h1>
        {description && <p class="article-desc">{description}</p>}
        <div class="article-meta">
          <div class="article-author">
            <img
              src="/images/logo.jpg"
              alt="קרן ולדמן חנן"
              width="40"
              height="40"
              class="author-avatar"
              loading="lazy"
            />
            <div>
              <span class="author-name">קרן ולדמן חנן</span>
              {formattedDate && (
                <time datetime={pubDate?.toISOString()} class="article-date">
                  {formattedDate}
                </time>
              )}
            </div>
          </div>
          <!-- Share buttons -->
          <div class="article-share" aria-label="שיתוף">
            <a
              href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.href)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="share-btn"
              aria-label="שתף בפייסבוק"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>
            <a
              href={`https://wa.me/?text=${encodeURIComponent(title + ' ' + Astro.url.href)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="share-btn share-btn--whatsapp"
              aria-label="שתף בוואטסאפ"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
              </svg>
            </a>
          </div>
        </div>
      </header>

      <div class="divider"></div>

      <!-- Article Body -->
      <div class="prose">
        <slot />
      </div>

      <!-- Tags -->
      {tags.length > 0 && (
        <footer class="article-tags">
          <span class="tags-label">תגיות:</span>
          {tags.map(tag => (
            <a href={`/blog/tag/${encodeURIComponent(tag)}`} class="badge">
              {tag}
            </a>
          ))}
        </footer>
      )}
    </div>

    <!-- CTA -->
    <Cta variant="minimal" />
  </article>
</BaseLayout>

<style>
  .article-page {
    padding-block-end: var(--space-16);
  }

  .article-hero {
    width: 100%;
    max-height: 480px;
    overflow: hidden;
    margin-block-end: var(--space-12);
  }

  .article-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .article-header {
    padding-block: var(--space-12) var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .article-title {
    font-size: var(--text-4xl);
    font-weight: 900;
    line-height: 1.25;
    color: var(--color-primary-dark);
  }

  .article-desc {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin: 0;
    max-width: 60ch;
  }

  .article-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .article-author {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .author-avatar {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-full);
    object-fit: cover;
    border: 2px solid var(--color-border);
  }

  .author-name {
    display: block;
    font-weight: 600;
    font-size: var(--text-sm);
    color: var(--color-text);
  }

  .article-date {
    display: block;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-block-start: 2px;
  }

  .article-share {
    display: flex;
    gap: var(--space-2);
  }

  .share-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-full);
    background: var(--color-bg-muted);
    color: var(--color-primary);
    transition: all var(--transition-fast);
    border: 1px solid var(--color-border-light);
  }

  .share-btn:hover {
    background: var(--color-primary);
    color: white;
    transform: translateY(-2px);
  }

  .share-btn--whatsapp:hover {
    background: #25D366;
  }

  .article-tags {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
    margin-block-start: var(--space-12);
    padding-block-start: var(--space-6);
    border-block-start: 1px solid var(--color-border-light);
  }

  .tags-label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .article-title {
      font-size: var(--text-3xl);
    }

    .article-meta {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
