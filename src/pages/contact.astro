---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="צור קשר | Crypto Women"
  description="תהיו בקשר! שלחו הודעה, כתבו מייל או צרו קשר בוואטסאפ. קרן ולדמן חנן — קריפטו, ביטקוין, קורסים וליווי."
>
  <section class="page-hero">
    <div class="container" style="text-align:center">
      <span class="badge">צרו קשר</span>
      <h1 class="page-hero-title">תהיו בקשר</h1>
      <p class="page-hero-subtitle">
        יש לכם שאלה? רוצים לשמוע עוד? כתבו לי ואחזור אליכם בהקדם
      </p>
    </div>
  </section>

  <section class="section contact-section">
    <div class="container contact-inner">

      <!-- CONTACT FORM -->
      <div class="contact-form-wrap">
        <h2 class="contact-form-title">השאירו הודעה</h2>
        <form
          id="contact-form"
          action="https://api.web3forms.com/submit"
          method="POST"
          novalidate
          aria-label="טופס יצירת קשר"
        >
          <!-- Web3Forms access key (public, safe to expose) -->
          <input type="hidden" name="access_key" value="YOUR_WEB3FORMS_KEY" />
          <input type="hidden" name="subject" value="פנייה חדשה מאתר Crypto Women" />
          <input type="hidden" name="redirect" value="https://cryptowomen-il.com/thank-you" />
          <!-- Honeypot anti-spam -->
          <input type="checkbox" name="botcheck" class="sr-only" tabindex="-1" aria-hidden="true" />

          <div class="form-group">
            <label for="name" class="form-label">שם מלא <span aria-label="שדה חובה">*</span></label>
            <input
              type="text"
              id="name"
              name="name"
              class="form-input"
              required
              autocomplete="name"
              placeholder="הזינו את שמכם"
            />
          </div>

          <div class="form-group">
            <label for="email" class="form-label">כתובת אימייל <span aria-label="שדה חובה">*</span></label>
            <input
              type="email"
              id="email"
              name="email"
              class="form-input"
              required
              autocomplete="email"
              placeholder="your@email.com"
              dir="ltr"
            />
          </div>

          <div class="form-group">
            <label for="phone" class="form-label">טלפון (אופציונלי)</label>
            <input
              type="tel"
              id="phone"
              name="phone"
              class="form-input"
              autocomplete="tel"
              placeholder="050-000-0000"
              dir="ltr"
            />
          </div>

          <div class="form-group">
            <label for="subject" class="form-label">נושא</label>
            <select id="subject" name="topic" class="form-input">
              <option value="">בחרו נושא...</option>
              <option value="course">מידע על הקורס</option>
              <option value="escort">ליווי פרטני</option>
              <option value="lecture">הרצאה</option>
              <option value="general">שאלה כללית</option>
              <option value="other">אחר</option>
            </select>
          </div>

          <div class="form-group">
            <label for="message" class="form-label">הודעה <span aria-label="שדה חובה">*</span></label>
            <textarea
              id="message"
              name="message"
              class="form-input form-textarea"
              required
              rows="5"
              placeholder="כתבו את הודעתכם כאן..."
            ></textarea>
          </div>

          <div id="form-status" class="form-status" role="alert" aria-live="polite" style="display:none"></div>

          <button type="submit" class="btn btn--primary btn--lg" id="submit-btn" style="width:100%">
            <span id="btn-text">שליחת הודעה</span>
            <span id="btn-loading" style="display:none" aria-label="שולח...">⏳</span>
          </button>

          <p class="form-disclaimer">
            הנתונים ישמשו לצורך מתן מענה בלבד ולא יועברו לצד שלישי.
          </p>
        </form>
      </div>

      <!-- CONTACT INFO -->
      <div class="contact-info">
        <h2 class="contact-info-title">דרכי יצירת קשר</h2>

        <div class="contact-cards">
          <a href="mailto:cryptowomen.il.mail@gmail.com" class="contact-card">
            <span class="contact-card-icon" aria-hidden="true">📧</span>
            <div>
              <div class="contact-card-label">מייל</div>
              <div class="contact-card-value" dir="ltr">cryptowomen.il.mail@gmail.com</div>
            </div>
          </a>

          <a href="https://wa.me/972546227530" target="_blank" rel="noopener noreferrer" class="contact-card contact-card--whatsapp">
            <span class="contact-card-icon" aria-hidden="true">💬</span>
            <div>
              <div class="contact-card-label">וואטסאפ</div>
              <div class="contact-card-value" dir="ltr"><bdo dir="ltr">054-622-7530</bdo></div>
            </div>
          </a>
        </div>

        <div class="contact-social">
          <h3 class="contact-social-title">עקבו אחריי ברשתות</h3>
          <div class="contact-social-links">
            <a href="https://www.instagram.com/keren_crypto_women/" target="_blank" rel="noopener noreferrer" class="social-pill social-pill--instagram">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
              אינסטגרם
            </a>
            <a href="https://www.facebook.com/keren.valdman" target="_blank" rel="noopener noreferrer" class="social-pill social-pill--facebook">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
              פייסבוק
            </a>
            <a href="https://www.youtube.com/@cryptowomen_il" target="_blank" rel="noopener noreferrer" class="social-pill social-pill--youtube">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M23.495 6.205a3.007 3.007 0 0 0-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 0 0 .527 6.205a31.247 31.247 0 0 0-.522 5.805 31.247 31.247 0 0 0 .522 5.783 3.007 3.007 0 0 0 2.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 0 0 2.088-2.088 31.247 31.247 0 0 0 .5-5.783 31.247 31.247 0 0 0-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/>
              </svg>
              יוטיוב
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    background: var(--gradient-hero);
    padding-block: var(--space-20);
  }

  .page-hero-title {
    font-size: var(--text-4xl);
    font-weight: 900;
    color: white;
    margin-block: var(--space-4) var(--space-4);
  }

  .page-hero-subtitle {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.8);
    max-width: 50ch;
    margin-inline: auto;
  }

  .contact-section {
    background: var(--color-bg-muted);
  }

  .contact-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-12);
    align-items: start;
  }

  /* FORM */
  .contact-form-wrap {
    background: white;
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    border: 1px solid var(--color-border-light);
  }

  .contact-form-title {
    font-size: var(--text-2xl);
    color: var(--color-primary-dark);
    margin-block-end: var(--space-8);
  }

  .form-group {
    margin-block-end: var(--space-5);
  }

  .form-label {
    display: block;
    font-weight: 600;
    font-size: var(--text-sm);
    color: var(--color-text);
    margin-block-end: var(--space-2);
  }

  .form-label span {
    color: var(--color-primary);
  }

  .form-input {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--color-text);
    background: white;
    transition: border-color var(--transition-fast);
    direction: rtl;
  }

  .form-input:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(91, 45, 142, 0.1);
  }

  .form-input::placeholder {
    color: var(--color-text-light);
  }

  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }

  .form-status {
    padding: var(--space-4);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: 600;
    margin-block-end: var(--space-4);
    text-align: center;
  }

  .form-status.success {
    background: #D1FAE5;
    color: #065F46;
    border: 1px solid #A7F3D0;
  }

  .form-status.error {
    background: #FEE2E2;
    color: #991B1B;
    border: 1px solid #FECACA;
  }

  .form-disclaimer {
    font-size: var(--text-xs);
    color: var(--color-text-light);
    text-align: center;
    margin-block-start: var(--space-3);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  /* CONTACT INFO */
  .contact-info {
    min-width: 300px;
  }

  .contact-info-title {
    font-size: var(--text-xl);
    color: var(--color-primary-dark);
    margin-block-end: var(--space-6);
  }

  .contact-cards {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-block-end: var(--space-8);
  }

  .contact-card {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-5);
    background: white;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border-light);
    text-decoration: none;
    color: inherit;
    transition: all var(--transition-fast);
  }

  .contact-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .contact-card--whatsapp:hover {
    border-color: #25D366;
  }

  .contact-card-icon {
    font-size: 1.75rem;
    flex-shrink: 0;
  }

  .contact-card-label {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-block-end: 2px;
  }

  .contact-card-value {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
  }

  .contact-social-title {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text-muted);
    margin-block-end: var(--space-4);
  }

  .contact-social-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .social-pill {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: 600;
    text-decoration: none;
    color: white;
    transition: all var(--transition-fast);
  }

  .social-pill:hover {
    transform: translateX(-3px);
    box-shadow: var(--shadow-sm);
  }

  .social-pill--instagram { background: linear-gradient(45deg, #f09433, #dc2743, #bc1888); }
  .social-pill--facebook { background: #1877F2; }
  .social-pill--youtube { background: #FF0000; }

  @media (max-width: 900px) {
    .contact-inner {
      grid-template-columns: 1fr;
    }
    .contact-info {
      min-width: unset;
    }
  }
</style>

<script>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            
</script>
