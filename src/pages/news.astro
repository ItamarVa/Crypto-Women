---
import BaseLayout from '../layouts/BaseLayout.astro';
import PriceTicker from '../components/PriceTicker.astro';
import BitcoinChart from '../components/BitcoinChart.astro';
import { withBase } from '../lib/url';
import news from '../data/news.json';

type NewsItem = {
  title: string;
  link: string;
  summary: string;
  source: string;
  lang: string;
  date: string | null;
  image: string | null;
};

const items = (news.items as NewsItem[]) ?? [];
const featured = items.slice(0, 3);
const rest = items.slice(3);

const dateFmt = new Intl.DateTimeFormat('he-IL', {
  day: 'numeric',
  month: 'long',
  hour: '2-digit',
  minute: '2-digit',
});
const fmtDate = (iso: string | null) => (iso ? dateFmt.format(new Date(iso)) : '');
const updatedLabel = news.updated
  ? new Intl.DateTimeFormat('he-IL', { dateStyle: 'long', timeStyle: 'short' }).format(new Date(news.updated))
  : '';

// Brand-tinted accent per source for the badge
const sourceColor: Record<string, string> = {
  Decrypt: '#6C5CE7',
  'The Defiant': '#00B894',
  'Bitcoin Magazine': '#F7931A',
  CoinDesk: '#0D74FF',
  Cointelegraph: '#FAB617',
  CryptoJungle: '#16A085',
  'Bitcoin Embassy TLV': '#E6007A',
};
const colorFor = (s: string) => sourceColor[s] ?? 'var(--color-primary)';

const description =
  'חדשות הקריפטו החמות מהעולם ומישראל, מחיר ביטקוין חי וגרף היסטורי — מתעדכן אוטומטית מהמקורות המובילים.';
---

<BaseLayout title="חדשות הקריפטו" description={description}>
  <!-- HERO + LIVE PRICE -->
  <section class="news-hero">
    <div class="container news-hero-inner">
      <div class="news-hero-copy">
        <span class="badge badge--accent news-kicker">עדכון חי · אוטומטי</span>
        <h1 class="news-title">חדשות הקריפטו</h1>
        <p class="news-lead">
          כל מה שחשוב ומעניין בעולם הביטקוין, הבלוקצ'יין והקריפטו — מישראל ומהעולם.
          מתעדכן אוטומטית מהמקורות המובילים, עם מחיר חי וגרף היסטורי.
        </p>
      </div>
      <div class="news-hero-ticker">
        <PriceTicker />
      </div>
    </div>
  </section>

  <div class="container news-body">
    <!-- HIGHLIGHTS -->
    {featured.length > 0 && (
      <section class="news-section" aria-labelledby="highlights-h">
        <div class="section-head">
          <h2 id="highlights-h" class="section-h">מובחרות עכשיו</h2>
          <span class="section-sub">הכותרות הבולטות מהשעות האחרונות</span>
        </div>
        <div class="highlights-grid">
          {featured.map((item, i) => (
            <a
              href={item.link}
              class={`highlight-card ${i === 0 ? 'highlight-card--lead' : ''}`}
              target="_blank"
              rel="noopener noreferrer"
            >
              <div class="highlight-media">
                {item.image ? (
                  <img src={item.image} alt="" loading={i === 0 ? 'eager' : 'lazy'} onerror="this.closest('.highlight-media').classList.add('no-img')" />
                ) : null}
                <span class="highlight-fallback" style={`--c:${colorFor(item.source)}`}>{item.source}</span>
              </div>
              <div class="highlight-content">
                <span class="src-badge" style={`--c:${colorFor(item.source)}`}>{item.source}</span>
                <h3 class="highlight-h" dir="auto">{item.title}</h3>
                {i === 0 && item.summary && <p class="highlight-desc" dir="auto">{item.summary}</p>}
                {item.date && <time class="news-time" datetime={item.date} data-ts={item.date}>{fmtDate(item.date)}</time>}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- BITCOIN CHART -->
    <section class="news-section" aria-labelledby="chart-h">
      <div class="section-head">
        <h2 id="chart-h" class="section-h">מחיר ביטקוין</h2>
        <span class="section-sub">היסטוריה אינטראקטיבית — זום והזזה</span>
      </div>
      <BitcoinChart />
    </section>

    <!-- LATEST NEWS GRID -->
    {rest.length > 0 && (
      <section class="news-section" aria-labelledby="latest-h">
        <div class="section-head">
          <h2 id="latest-h" class="section-h">עוד מהשטח</h2>
          <span class="section-sub">{items.length} כתבות מ-{news.sources.length} מקורות</span>
        </div>
        <div class="news-grid">
          {rest.map((item) => (
            <a href={item.link} class="news-card" target="_blank" rel="noopener noreferrer">
              <div class="news-card-media">
                {item.image ? (
                  <img src={item.image} alt="" loading="lazy" onerror="this.closest('.news-card-media').classList.add('no-img')" />
                ) : null}
                <span class="news-card-fallback" style={`--c:${colorFor(item.source)}`}>{item.source}</span>
              </div>
              <div class="news-card-body">
                <span class="src-badge src-badge--sm" style={`--c:${colorFor(item.source)}`}>{item.source}</span>
                <h3 class="news-card-h" dir="auto">{item.title}</h3>
                {item.date && <time class="news-time" datetime={item.date} data-ts={item.date}>{fmtDate(item.date)}</time>}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <p class="news-updated">
      <span class="live-dot-sm" aria-hidden="true"></span>
      עודכן לאחרונה: {updatedLabel} · מתעדכן אוטומטית מספר פעמים ביום.
      הכתבות מובאות מ-{news.sources.join(', ')} ומקושרות למקור המלא.
    </p>
  </div>
</BaseLayout>

<style>
  /* HERO */
  .news-hero {
    background: var(--gradient-hero);
    padding-block: var(--space-16);
    position: relative;
    overflow: hidden;
  }
  .news-hero::after {
    content: '';
    position: absolute;
    inset-block-start: -40%;
    inset-inline-start: -10%;
    width: 60%;
    height: 160%;
    background: radial-gradient(circle, rgba(201, 168, 76, 0.18), transparent 70%);
    pointer-events: none;
  }
  .news-hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: center;
    position: relative;
    z-index: 1;
  }
  .news-kicker { background: rgba(201, 168, 76, 0.18); }
  .news-title {
    color: #fff;
    font-size: var(--text-4xl);
    margin-block: var(--space-4) var(--space-3);
  }
  .news-lead {
    color: rgba(255, 255, 255, 0.82);
    font-size: var(--text-lg);
    max-width: 46ch;
    margin: 0;
  }

  /* BODY */
  .news-body { padding-block: var(--space-16); }
  .news-section { margin-block-end: var(--space-20); }
  .section-head {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-block-end: var(--space-6);
    padding-block-end: var(--space-3);
    border-block-end: 2px solid var(--color-border-light);
  }
  .section-h { font-size: var(--text-2xl); color: var(--color-primary-dark); margin: 0; }
  .section-sub { color: var(--color-text-muted); font-size: var(--text-sm); }

  /* SHARED badge + media */
  .src-badge {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    padding: 2px 10px;
    border-radius: var(--radius-full);
    font-size: 0.72rem;
    font-weight: 700;
    color: #fff;
    background: var(--c);
    direction: ltr;
  }
  .src-badge--sm { font-size: 0.68rem; padding: 2px 8px; }
  .news-time {
    color: var(--color-text-light);
    font-size: var(--text-xs);
    font-variant-numeric: tabular-nums;
  }

  /* HIGHLIGHTS */
  .highlights-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    grid-template-rows: auto auto;
    gap: var(--space-5);
  }
  .highlight-card {
    display: flex;
    flex-direction: column;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition-base), box-shadow var(--transition-base), border-color var(--transition-base);
    color: inherit;
  }
  .highlight-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-primary);
    color: inherit;
  }
  .highlight-card--lead {
    grid-row: 1 / 3;
  }
  .highlight-media {
    position: relative;
    aspect-ratio: 16 / 9;
    background: var(--color-bg-muted);
    overflow: hidden;
  }
  /* Lead card spans two rows — let the image fill the extra height
     instead of stretching the text block and leaving a gap. */
  .highlight-card--lead .highlight-media { aspect-ratio: auto; flex: 1 1 auto; min-height: 320px; }
  .highlight-card--lead .highlight-content { flex: 0 0 auto; }
  .highlight-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: relative;
    z-index: 1;
  }
  .highlight-fallback,
  .news-card-fallback {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: var(--text-lg);
    color: #fff;
    background: linear-gradient(135deg, var(--c), color-mix(in srgb, var(--c) 60%, #1A0A2E));
    direction: ltr;
    z-index: 0;
  }
  .highlight-media.no-img img,
  .news-card-media.no-img img { display: none; }
  .highlight-content {
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1;
  }
  .highlight-h {
    font-size: var(--text-lg);
    line-height: 1.35;
    margin: 0;
    color: var(--color-text);
  }
  .highlight-card--lead .highlight-h { font-size: var(--text-xl); }
  .highlight-desc {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    margin: 0;
    line-height: 1.6;
  }
  .news-time { margin-block-start: auto; }

  /* LATEST GRID */
  .news-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-5);
  }
  .news-card {
    display: flex;
    flex-direction: column;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition-base), box-shadow var(--transition-base), border-color var(--transition-base);
    color: inherit;
  }
  .news-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-primary);
    color: inherit;
  }
  .news-card-media {
    position: relative;
    aspect-ratio: 16 / 9;
    background: var(--color-bg-muted);
    overflow: hidden;
  }
  .news-card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: relative;
    z-index: 1;
  }
  .news-card-body {
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    flex: 1;
  }
  .news-card-h {
    font-size: var(--text-base);
    line-height: 1.4;
    margin: 0;
    color: var(--color-text);
    /* clamp to 3 lines */
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* UPDATED footer line */
  .news-updated {
    text-align: center;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    max-width: 70ch;
    margin-inline: auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  .live-dot-sm {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #2ecc71;
    display: inline-block;
  }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .news-hero-inner { grid-template-columns: 1fr; gap: var(--space-8); }
    .news-lead { max-width: none; }
    .highlights-grid { grid-template-columns: 1fr; }
    .highlight-card--lead { grid-row: auto; }
  }
</style>

<script>
  // Convert build-time dates to live relative labels ("לפני 3 שעות")
  function relize() {
    const rtf = new Intl.RelativeTimeFormat('he', { numeric: 'auto' });
    document.querySelectorAll<HTMLTimeElement>('.news-time[data-ts]').forEach((el) => {
      const ts = Date.parse(el.dataset.ts || '');
      if (Number.isNaN(ts)) return;
      const diffMin = Math.round((ts - Date.now()) / 60000);
      const absMin = Math.abs(diffMin);
      let label: string;
      if (absMin < 60) label = rtf.format(diffMin, 'minute');
      else if (absMin < 60 * 24) label = rtf.format(Math.round(diffMin / 60), 'hour');
      else label = rtf.format(Math.round(diffMin / (60 * 24)), 'day');
      el.textContent = label;
    });
  }
  document.addEventListener('astro:page-load', relize);
  relize();
</script>
