---
import BaseLayout from '../layouts/BaseLayout.astro';

const books = [
  {
    title: 'מה זה בלוקצ\'יין?',
    desc: 'דמיינו עולם שבו אפשר לסמוך על כל עסקה, להעביר כספים או לנהל נתונים — ללא בנקים, מתווכים או סיכוני הונאה. זהו העולם של הבלוקצ\'יין. בספרון זה תגלו את הטכנולוגיה שמשנה את חוקי המשחק.',
    img: '/images/block_master_optimized.jpg',
    link: 'https://www.e-vrit.co.il/Product/34843',
    tag: 'בלוקצ\'יין',
  },
  {
    title: 'מה זה NFT?',
    desc: 'מה הופך תמונה דיגיטלית ליצירת אמנות ששווה מיליונים? הספרון הזה לוקח אתכם למסע מרתק בעולם ה-NFT, בו כל יצירה היא ייחודית וכל נכס דיגיטלי יכול להפוך להשקעה יקרת ערך.',
    img: '/images/nft_master_optimized.jpg',
    link: 'https://www.e-vrit.co.il/Product/34842',
    tag: 'NFT',
  },
  {
    title: 'מה זה CBDC?',
    desc: 'בעולם שבו הכסף הופך לדיגיטלי יותר מאי פעם, מדינות רבות בוחנות מטבעות דיגיטליים של בנקים מרכזיים. מה זה אומר? איך זה פועל? ואילו שינויים פוטנציאליים זה יביא לכלכלה ולחיי היום-יום שלנו?',
    img: '/images/cbdc_master_1_optimized.jpg',
    link: 'https://www.e-vrit.co.il/Product/34818',
    tag: 'CBDC',
  },
];
---

<BaseLayout
  title="ספרונים — ידע קריפטו מהיר ומדויק | Crypto Women"
  description="ספרונים קצרים מאת קרן ולדמן חנן על בלוקצ'יין, NFT ו-CBDC. ידע מהיר במחיר שווה לכל כיס — מינימום מילים, מקסימום הבנה."
>
  <!-- HERO -->
  <section class="books-hero">
    <div class="container hero-inner">
      <div class="hero-text">
        <span class="badge badge--accent">ספרונים דיגיטליים</span>
        <h1 class="hero-title">ספרונים קצרים מאת קריפטו וומן</h1>
        <p class="hero-sub">
          ידע מהיר במחיר שווה לכל כיס — מינימום מילים, מקסימום הבנה!
        </p>
        <p class="hero-lead">
          העולם הפיננסי משתנה — בלוקצ'יין, מטבעות דיגיטליים, NFT ו-CBDC הופכים לחלק מהמציאות.
          אבל איך מבינים את זה בלי לבזבז שעות של למידה?
        </p>
        <a
          href="https://www.e-vrit.co.il/Author/19149"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn--primary btn--lg"
        >
          לכל הספרונים ב-e-vrit ●
        </a>
      </div>
    </div>
  </section>

  <!-- BOOKS GRID -->
  <section class="section books-section">
    <div class="container">
      <div class="section-header" style="text-align:center; margin-block-end: var(--space-12)">
        <span class="badge">מה מחכה לכם</span>
        <h2 style="font-size: var(--text-3xl); color: var(--color-primary-dark); margin-block: var(--space-3)">
          בחרו ספרון, קבלו גישה מיידית
        </h2>
        <p style="color: var(--color-text-muted); font-size: var(--text-lg); max-width: 55ch; margin-inline: auto">
          תוכן ברור, ישיר ולעניין — ובמחיר שווה לכל כיס
        </p>
      </div>

      <div class="books-grid">
        {books.map((book) => (
          <article class="book-card">
            <a href={book.link} target="_blank" rel="noopener noreferrer" class="book-img-link">
              <img
                src={book.img}
                alt={book.title}
                width="300"
                height="470"
                loading="lazy"
                class="book-cover"
              />
            </a>
            <div class="book-body">
              <span class="book-tag">{book.tag}</span>
              <h2 class="book-title">{book.title}</h2>
              <p class="book-desc">{book.desc}</p>
              <a
                href={book.link}
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn--primary"
              >
                לרכישה ●
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY -->
  <section class="section why-section">
    <div class="container--content">
      <div class="why-inner">
        <h2 class="why-title">למה הספרונים האלה שונים?</h2>
        <div class="why-grid">
          <div class="why-item">
            <div class="why-icon">⚡</div>
            <h3>קצר ולעניין</h3>
            <p>ספרונים קצרים שאפשר לקרוא בשעה — ללא מילוי מיותר</p>
          </div>
          <div class="why-item">
            <div class="why-icon">🎯</div>
            <h3>ממוקד ומדויק</h3>
            <p>כל ספרון עוסק בנושא אחד לעומק — ידע שיישאר אתכם</p>
          </div>
          <div class="why-item">
            <div class="why-icon">💡</div>
            <h3>נגיש לכולם</h3>
            <p>לא נדרש ידע מקדים — הסברים בשפה ברורה וממחישה</p>
          </div>
          <div class="why-item">
            <div class="why-icon">💰</div>
            <h3>מחיר שווה לכל כיס</h3>
            <p>השקעה קטנה, ידע גדול — כלכלת ידע שנגישה לכולם</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .books-hero {
    background: var(--gradient-hero);
    padding-block: var(--space-20);
  }
  .hero-inner {
    max-width: 700px;
    margin-inline: auto;
    text-align: center;
  }
  .hero-title {
    font-size: var(--text-4xl);
    font-weight: 900;
    color: white;
    margin-block: var(--space-4);
    line-height: 1.2;
  }
  .hero-sub {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-accent-light, #f0d080);
    margin-block-end: var(--space-4);
  }
  .hero-lead {
    font-size: var(--text-base);
    color: rgba(255,255,255,0.85);
    margin-block-end: var(--space-8);
    max-width: 55ch;
    margin-inline: auto;
    line-height: 1.7;
  }

  .books-section { background: var(--color-bg-muted); }

  .books-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-8);
    justify-items: center;
  }

  .book-card {
    background: white;
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--color-border-light);
    box-shadow: var(--shadow-md);
    max-width: 340px;
    width: 100%;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    display: flex;
    flex-direction: column;
  }
  .book-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-xl, 0 20px 40px rgba(0,0,0,0.15));
  }

  .book-img-link { display: block; overflow: hidden; }

  .book-cover {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.3s ease;
  }
  .book-card:hover .book-cover { transform: scale(1.04); }

  .book-body {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1;
  }

  .book-tag {
    display: inline-block;
    background: var(--color-primary-light, #7b4db0);
    color: white;
    font-size: var(--text-xs);
    font-weight: 700;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    width: fit-content;
    letter-spacing: 0;
  }

  .book-title {
    font-size: var(--text-xl);
    font-weight: 800;
    color: var(--color-primary-dark);
    margin: 0;
    line-height: 1.3;
  }

  .book-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0;
    flex: 1;
  }

  .why-section { background: white; }

  .why-inner {
    max-width: 800px;
    margin-inline: auto;
    text-align: center;
  }
  .why-title {
    font-size: var(--text-3xl);
    color: var(--color-primary-dark);
    margin-block-end: var(--space-10);
  }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
  }

  .why-item {
    background: var(--color-bg-muted);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    text-align: center;
  }
  .why-icon {
    font-size: 2rem;
    margin-block-end: var(--space-3);
  }
  .why-item h3 {
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-primary-dark);
    margin-block-end: var(--space-2);
  }
  .why-item p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 600px) {
    .why-grid { grid-template-columns: 1fr; }
  }
</style>
